/* ============================================================
   AI SLOT (live Claude + heuristic fallback)
   ============================================================ */
function renderAISlot(id,kind,d,big){
  const el=document.getElementById(id); if(!el) return;
  const key=kind+'|'+JSON.stringify(filters);
  el.innerHTML=`<div class="ai-panel">
    <div class="ai-head">
      <div class="ai-orb"><svg viewBox="0 0 24 24" fill="none" stroke="#000" stroke-width="2"><path d="M12 2l2 5 5 .5-3.8 3.4L16.5 16 12 13l-4.5 3 1.3-5.1L5 7.5 10 7z"/></svg></div>
      <div><div class="ai-title">Análisis <b>IA</b></div><div style="font-size:10.5px;color:var(--muted);font-weight:600">${aiSub(kind,d.length)}</div></div>
      <div class="ai-chip load" id="${id}-chip">● Procesando</div>
      <div class="ai-regen" id="${id}-regen" title="Regenerar análisis"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M23 4v6h-6M1 20v-6h6"/><path d="M3.5 9a9 9 0 0114.9-3.4L23 10M1 14l4.6 4.4A9 9 0 0020.5 15"/></svg></div>
    </div>
    <div class="ai-body" id="${id}-body">${shimmer(big?7:5)}</div>
  </div>`;
  document.getElementById(id+'-regen').onclick=()=>{ delete aiCache[key]; runAI(id,kind,d,key); };
  if(aiCache[key]){ paintAI(id,aiCache[key].html,aiCache[key].live); }
  else { runAI(id,kind,d,key); }
}
function aiSub(k,n){
  const m={resumen:'Resumen ejecutivo del avance general',objetivos:'Lectura por objetivos estratégicos',
    dependencias:'Lectura por dependencias',narrativa:'Conclusiones para la próxima sesión'};
  return (m[k]||'')+` · ${n} acciones en alcance`;
}
function shimmer(n){ return Array(n).fill(0).map((_,i)=>`<div class="shimmer-line" style="width:${[100,92,96,70,88,94,60][i%7]}%"></div>`).join(''); }

function runAI(id,kind,d,key){
  const chip=document.getElementById(id+'-chip');
  if(chip){chip.className='ai-chip load';chip.textContent='● Procesando';}
  if(aiDebounce) clearTimeout(aiDebounce);
  aiDebounce=setTimeout(async()=>{
    let html=null, live=false;
    try{ html=await callClaude(kind,d); live=true; }
    catch(e){ html=heuristicNarrative(kind,d); live=false; }
    if(!html){ html=heuristicNarrative(kind,d); live=false; }
    aiCache[key]={html,live};
    paintAI(id,html,live);
  },350);
}
function paintAI(id,html,live){
  const body=document.getElementById(id+'-body'), chip=document.getElementById(id+'-chip');
  if(body) body.innerHTML=html;
  if(chip){ chip.className='ai-chip '+(live?'live':'off'); chip.textContent=live?'⚡ IA en vivo':'◆ Análisis automático'; }
}

/* ---- live Claude call ---- */
async function callClaude(kind,d){
  const ctx=buildContext(d);
  const sys=`Eres un consultor senior en Business Intelligence y análisis de políticas públicas de juventud, evaluando el Plan de Acción de la Comisión de Concertación y Decisión Juvenil (CCyD) de Zipaquirá. Analizas EXCLUSIVAMENTE la información entregada (no inventes datos, cifras ni dependencias). Interpretas el avance: nivel de ejecución, calidad, cumplimiento frente al objetivo, riesgos, pendientes, impacto y coherencia entre indicador y acciones. Escribe en español, tono ejecutivo y claro, sin relleno. Usa SOLO etiquetas HTML simples: <h4>, <p>, <ul>, <li>, <strong>. No uses markdown ni bloques de código.`;
  const ask={
    resumen:`Redacta el ANÁLISIS EJECUTIVO del avance general. Incluye con <h4>: "Panorama general", "Fortalezas", "Acciones con mayor desarrollo", "Requieren seguimiento", "Dependencias con mayor participación", "Recomendaciones". Sé conciso (máx ~280 palabras).`,
    objetivos:`Analiza el avance POR OBJETIVOS. Con <h4> separa: "Objetivos más avanzados", "Objetivos rezagados", "Coherencia indicador–acción", "Recomendación". Máx ~240 palabras.`,
    dependencias:`Analiza el desempeño POR DEPENDENCIAS. Con <h4>: "Dependencias líderes", "Articulación interinstitucional", "Dependencias por activar", "Recomendación". Máx ~240 palabras.`,
    narrativa:`Genera una NARRATIVA argumentada respondiendo, cada una con su <h4>: "¿En qué se ha concentrado el trabajo?", "Acciones de mayor impacto", "Temas recurrentes", "Dependencias que lideran", "Riesgos identificados", "Actividades posiblemente retrasadas", "Recomendaciones para la próxima sesión", "Acciones a priorizar". Argumenta con base en las descripciones. Máx ~360 palabras.`
  }[kind];
  const resp=await fetch("https://api.anthropic.com/v1/messages",{
    method:"POST",headers:{"Content-Type":"application/json"},
    body:JSON.stringify({model:"claude-sonnet-4-6",max_tokens:1000,system:sys,
      messages:[{role:"user",content:ask+"\n\n=== DATOS DEL PLAN (acciones en alcance) ===\n"+ctx}]})
  });
  if(!resp.ok) throw new Error('http '+resp.status);
  const data=await resp.json();
  const txt=data.content.filter(b=>b.type==='text').map(b=>b.text).join('\n').trim();
  if(!txt) throw new Error('empty');
  return sanitizeAI(txt);
}
function buildContext(d){
  return d.map((r,i)=>{
    const a=r._a;
    return `#${i+1} OBJETIVO: ${r.objetivo||'-'}
ACTIVIDAD: ${r.accion||'-'} | INDICADOR: ${r.indicador||'-'} | RESPONSABLE: ${r.responsable||'-'}
META: ${r.metaIndicador??'-'} EJECUCIÓN: ${r.ejecucion??'-'} | AVANCE_AUTO: ${a.avance}
DESCRIPCIÓN DE ACCIONES REALIZADAS: ${r.descripcion||'(sin registro)'}`;
  }).join('\n---\n').slice(0,14000);
}
function sanitizeAI(t){
  t=t.replace(/```html|```/g,'').trim();
  if(!/<h4|<p|<ul|<li/.test(t)) t='<p>'+t.replace(/\n{2,}/g,'</p><p>').replace(/\n/g,'<br>')+'</p>';
  return t;
}

/* ---- heuristic narrative fallback (siempre funciona, también offline) ---- */
function heuristicNarrative(kind,d){
  if(!d.length) return '<p>No hay acciones en el alcance del filtro actual.</p>';
  const dist=countAvance(d);
  const depMap={}; d.forEach(r=>r._deps.forEach(x=>depMap[x]=(depMap[x]||0)+1));
  const topDeps=Object.entries(depMap).sort((a,b)=>b[1]-a[1]).slice(0,3);
  const themes={}; d.forEach(r=>r._a.themes.forEach(t=>themes[t]=(themes[t]||0)+1));
  const topThemes=Object.entries(themes).sort((a,b)=>b[1]-a[1]).slice(0,4).map(x=>x[0]);
  const best=d.filter(r=>r._a.color==='alto').slice(0,3);
  const watch=d.filter(r=>r._a.color==='bajo'||r._a.color==='sin').slice(0,3);
  const avg=avgPct(d);

  if(kind==='resumen'){
    return `<h4>Panorama general</h4><p>El plan registra <strong>${d.length} acciones</strong> con un avance promedio del <strong>${avg}%</strong> frente a las metas: ${dist.alto} con avance alto, ${dist.medio} medio, ${dist.bajo} bajo y ${dist.sin} sin descripción registrada. ${topThemes.length?`El trabajo se concentra en <strong>${topThemes.join(', ')}</strong>.`:''}</p>
    <h4>Fortalezas</h4><ul>${best.map(r=>`<li>${esc((r.accion||r.indicador).slice(0,90))}</li>`).join('')||'<li>Articulación interinstitucional evidenciada en varias acciones.</li>'}</ul>
    <h4>Requieren seguimiento</h4><ul>${watch.map(r=>`<li>${esc((r.accion||r.indicador).slice(0,90))} — ${r._a.hasDesc?'avance por consolidar':'sin descripción registrada'}</li>`).join('')||'<li>Sin alertas críticas en el alcance actual.</li>'}</ul>
    <h4>Dependencias con mayor participación</h4><ul>${topDeps.map(x=>`<li><strong>${esc(x[0])}</strong> — ${x[1]} actividades</li>`).join('')}</ul>
    <h4>Recomendaciones</h4><p>Fortalecer el registro cuantitativo de las acciones sin dato de ejecución y sistematizar evidencia de impacto para la próxima sesión de seguimiento de la Comisión.</p>`;
  }
  if(kind==='objetivos'){
    const g=groupBy(d,'objetivo'); const ks=Object.keys(g).sort((a,b)=>avgPct(g[b])-avgPct(g[a]));
    return `<h4>Objetivos más avanzados</h4><ul>${ks.slice(0,3).map(k=>`<li><strong>${esc(k.slice(0,70))}</strong> — ${avgPct(g[k])}%</li>`).join('')}</ul>
    <h4>Objetivos rezagados</h4><ul>${ks.slice(-3).reverse().map(k=>`<li>${esc(k.slice(0,70))} — ${avgPct(g[k])}%</li>`).join('')}</ul>
    <h4>Coherencia indicador–acción</h4><p>Las descripciones disponibles guardan relación con sus indicadores; las brechas se concentran donde falta el dato cuantitativo de ejecución.</p>
    <h4>Recomendación</h4><p>Acelerar los objetivos rezagados y cuantificar el impacto de los más avanzados.</p>`;
  }
  if(kind==='dependencias'){
    return `<h4>Dependencias líderes</h4><ul>${topDeps.map(x=>`<li><strong>${esc(x[0])}</strong> — ${x[1]} actividades</li>`).join('')}</ul>
    <h4>Articulación interinstitucional</h4><p>Varias acciones se ejecutan de forma conjunta entre secretarías, el Consejo de Juventudes y la Casa de la Juventud, lo que evidencia trabajo en red.</p>
    <h4>Recomendación</h4><p>Activar a las dependencias con menor reporte y mantener la articulación en las acciones de mayor impacto.</p>`;
  }
  // narrativa
  return `<h4>¿En qué se ha concentrado el trabajo?</h4><p>El esfuerzo de la Comisión se concentra en <strong>${topThemes.join(', ')||'gestión institucional y participación juvenil'}</strong>, con ${d.length} acciones en seguimiento.</p>
  <h4>Acciones de mayor impacto</h4><ul>${best.map(r=>`<li>${esc((r.accion||r.indicador).slice(0,90))}</li>`).join('')||'<li>Acciones de articulación en Casa de la Juventud y salud mental.</li>'}</ul>
  <h4>Temas recurrentes</h4><p>${topThemes.join(', ')||'articulación, participación y formación'}.</p>
  <h4>Dependencias que lideran</h4><p>${topDeps.map(x=>esc(x[0])+' ('+x[1]+')').join(', ')}.</p>
  <h4>Riesgos identificados</h4><p>${dist.sin} acciones sin descripción y ${dist.bajo} con avance bajo representan el principal riesgo de subregistro y retraso.</p>
  <h4>Actividades posiblemente retrasadas</h4><ul>${watch.map(r=>`<li>${esc((r.accion||r.indicador).slice(0,90))}</li>`).join('')||'<li>Sin retrasos evidentes en el alcance actual.</li>'}</ul>
  <h4>Recomendaciones para la próxima sesión</h4><p>Priorizar el cierre de brechas cuantitativas, documentar evidencia de impacto y dar impulso a las acciones rezagadas.</p>`;
}

/* ---- per-card deep analysis ---- */
async function deepAnalyze(btn){
  const r=DATA.find(x=>String(x.id)===btn.dataset.id); if(!r) return;
  const card=btn.closest('.ind-card'); const slot=card.querySelector('[data-aitext]');
  btn.disabled=true; btn.textContent='⚡ Analizando…';
  const old=slot.innerHTML; slot.innerHTML=shimmer(3);
  try{
    const sys=`Eres consultor senior en evaluación de políticas públicas de juventud. Analiza SOLO la información dada de UNA acción del Plan de Acción de la CCyD de Zipaquirá. Devuelve un párrafo ejecutivo (máx 90 palabras) interpretando: nivel de ejecución, coherencia indicador-acción, riesgo, impacto y una recomendación concreta. Español, sin markdown, sin viñetas, solo texto.`;
    const u=`INDICADOR: ${r.indicador}\nOBJETIVO: ${r.objetivo}\nRESPONSABLE: ${r.responsable}\nMETA: ${r.metaIndicador} EJECUCIÓN: ${r.ejecucion}\nDESCRIPCIÓN DE ACCIONES REALIZADAS: ${r.descripcion||'(sin registro)'}`;
    const resp=await fetch("https://api.anthropic.com/v1/messages",{method:"POST",headers:{"Content-Type":"application/json"},
      body:JSON.stringify({model:"claude-sonnet-4-6",max_tokens:1000,system:sys,messages:[{role:"user",content:u}]})});
    if(!resp.ok) throw 0;
    const data=await resp.json();
    const t=data.content.filter(b=>b.type==='text').map(b=>b.text).join(' ').trim();
    slot.innerHTML=t?esc(t).replace(/\n/g,'<br>'):old;
    slot.style.borderLeftColor='var(--yellow)';
    btn.textContent='✓ Analizado'; toast('Análisis IA generado');
  }catch(e){
    slot.innerHTML=old; btn.disabled=false; btn.textContent='⚡ Profundizar IA';
    toast('IA no disponible — se muestra el análisis automático');
  }
}

/* ============================================================
