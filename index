<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Parche Zipa · Plan de Acción CCyD 2026</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Poppins:ital,wght@0,400;0,500;0,600;0,700;0,800;0,900;1,800;1,900&display=swap" rel="stylesheet">
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>
<style>
:root{
  --ink:#0A0A0B; --ink2:#121214; --card:#17171A; --card2:#1E1E22;
  --line:#2A2A2F; --yellow:#F4E500; --green:#2BE86B; --green-d:#13c456;
  --white:#FFFFFF; --muted:#8C8C93; --muted2:#5E5E66; --red:#FF4D5E;
  --shadow:6px 6px 0 #000; --shadow-sm:4px 4px 0 #000;
  --r:18px; --r-sm:12px;
}
*{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth}
body{
  font-family:'Poppins',system-ui,sans-serif;background:var(--ink);color:var(--white);
  min-height:100vh;overflow-x:hidden;
  background-image:radial-gradient(circle at 12% 8%, rgba(244,229,0,.06), transparent 38%),
                   radial-gradient(circle at 88% 92%, rgba(43,232,107,.06), transparent 42%),
                   linear-gradient(rgba(255,255,255,.012) 1px, transparent 1px),
                   linear-gradient(90deg, rgba(255,255,255,.012) 1px, transparent 1px);
  background-size:auto,auto,46px 46px,46px 46px;
}
::-webkit-scrollbar{width:10px;height:10px}
::-webkit-scrollbar-track{background:var(--ink2)}
::-webkit-scrollbar-thumb{background:#33333a;border-radius:10px}
::-webkit-scrollbar-thumb:hover{background:var(--yellow)}

/* ===== LAYOUT ===== */
.app{display:flex;min-height:100vh}
.sidebar{
  width:248px;flex-shrink:0;background:var(--ink2);border-right:2px solid #000;
  position:sticky;top:0;height:100vh;display:flex;flex-direction:column;padding:20px 16px;z-index:40;
  transition:width .25s ease;
}
.sidebar.collapsed{width:78px}
.brand{display:flex;align-items:center;gap:12px;margin-bottom:26px;min-height:52px}
.brand-logo{width:48px;height:48px;flex-shrink:0;filter:drop-shadow(2px 2px 0 #000)}
.brand-txt{font-weight:900;line-height:1;letter-spacing:-.5px}
.brand-txt .b1{font-size:18px;font-style:italic;color:var(--yellow);text-shadow:1.5px 1.5px 0 #000}
.brand-txt .b2{font-size:12px;color:var(--green);font-weight:800;letter-spacing:1px}
.sidebar.collapsed .brand-txt,.sidebar.collapsed .nav-label,.sidebar.collapsed .side-foot-txt{display:none}

.nav{display:flex;flex-direction:column;gap:6px;flex:1}
.nav-item{
  display:flex;align-items:center;gap:13px;padding:11px 13px;border-radius:var(--r-sm);
  cursor:pointer;color:var(--muted);font-weight:600;font-size:14px;border:2px solid transparent;
  transition:.15s;position:relative;user-select:none;white-space:nowrap;
}
.nav-item svg{width:21px;height:21px;flex-shrink:0}
.nav-item:hover{background:#202024;color:var(--white)}
.nav-item.active{background:var(--yellow);color:#000;border-color:#000;box-shadow:var(--shadow-sm);font-weight:800;transform:translateX(2px)}
.nav-item.active svg{stroke:#000}
.nav-num{position:absolute;right:11px;font-size:11px;font-weight:800;opacity:.5}
.sidebar.collapsed .nav-num{display:none}

.side-foot{margin-top:auto;padding-top:14px;border-top:1px solid var(--line);display:flex;align-items:center;justify-content:space-between}
.side-foot-txt{font-size:10px;color:var(--muted2);line-height:1.3}
/* hidden admin trigger = lightning dot */
.admin-dot{width:16px;height:16px;border-radius:50%;cursor:pointer;opacity:.14;flex-shrink:0;transition:.2s;display:grid;place-items:center}
.admin-dot:hover{opacity:.85}
.admin-dot svg{width:13px;height:13px}

.main{flex:1;min-width:0;display:flex;flex-direction:column}

/* ===== TOPBAR / FILTERS ===== */
.topbar{
  position:sticky;top:0;z-index:30;background:rgba(10,10,11,.86);backdrop-filter:blur(10px);
  border-bottom:2px solid #000;padding:14px 26px;display:flex;align-items:center;gap:14px;flex-wrap:wrap;
}
.burger{background:var(--card);border:2px solid #000;border-radius:10px;width:40px;height:40px;display:grid;place-items:center;cursor:pointer;color:var(--white);flex-shrink:0}
.burger:hover{background:var(--yellow);color:#000}
.page-title{font-weight:900;font-size:19px;font-style:italic;letter-spacing:-.5px;margin-right:auto;text-transform:uppercase}
.page-title b{color:var(--yellow)}
.filters{display:flex;gap:10px;flex-wrap:wrap;align-items:center}
.fbox{position:relative}
.fbox label{position:absolute;top:-7px;left:11px;font-size:9px;font-weight:800;color:var(--green);background:var(--ink);padding:0 5px;text-transform:uppercase;letter-spacing:.5px;border-radius:4px}
select{
  appearance:none;background:var(--card);color:var(--white);border:2px solid #000;border-radius:10px;
  padding:9px 32px 9px 13px;font-family:inherit;font-weight:600;font-size:12.5px;cursor:pointer;
  max-width:200px;text-overflow:ellipsis;box-shadow:var(--shadow-sm);transition:.15s;
}
select:hover{border-color:var(--yellow)}
select:focus{outline:none;border-color:var(--green)}
.fbox::after{content:"▾";position:absolute;right:12px;top:9px;color:var(--yellow);pointer-events:none;font-size:13px}
.btn-clear{background:var(--red);color:#fff;border:2px solid #000;border-radius:10px;padding:9px 14px;font-weight:800;font-size:12px;cursor:pointer;box-shadow:var(--shadow-sm);display:flex;align-items:center;gap:6px}
.btn-clear:hover{transform:translate(-1px,-1px);box-shadow:5px 5px 0 #000}
.btn-clear:active{transform:translate(2px,2px);box-shadow:2px 2px 0 #000}

.content{padding:26px;max-width:1500px;width:100%;margin:0 auto}
.page{display:none;animation:fade .4s ease}
.page.active{display:block}
@keyframes fade{from{opacity:0;transform:translateY(12px)}to{opacity:1;transform:none}}

/* ===== STICKER / SECTION HEADERS ===== */
.tag{
  display:inline-flex;align-items:center;gap:9px;background:var(--yellow);color:#000;font-weight:900;
  font-style:italic;text-transform:uppercase;font-size:13px;letter-spacing:.5px;padding:7px 15px;
  border:2.5px solid #000;border-radius:10px;box-shadow:var(--shadow-sm);transform:rotate(-1.4deg);margin-bottom:18px;
}
.tag.green{background:var(--green)}
.tag svg{width:17px;height:17px}
.section-gap{margin-top:34px}

/* ===== KPI CARDS ===== */
.kpi-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(165px,1fr));gap:16px}
.kpi{
  background:var(--card);border:2.5px solid #000;border-radius:var(--r);padding:18px 18px 16px;
  box-shadow:var(--shadow);position:relative;overflow:hidden;transition:.2s;opacity:0;transform:translateY(16px);
}
.kpi.in{opacity:1;transform:none}
.kpi:hover{transform:translateY(-4px) rotate(-.6deg);box-shadow:8px 9px 0 #000}
.kpi::before{content:"";position:absolute;top:0;left:0;width:100%;height:5px;background:var(--accent,var(--yellow))}
.kpi-ico{width:38px;height:38px;border-radius:10px;background:var(--accent,var(--yellow));border:2px solid #000;display:grid;place-items:center;margin-bottom:12px}
.kpi-ico svg{width:21px;height:21px;stroke:#000}
.kpi-val{font-size:38px;font-weight:900;line-height:1;font-style:italic;letter-spacing:-1.5px}
.kpi-lab{font-size:11.5px;color:var(--muted);font-weight:600;margin-top:7px;line-height:1.25;text-transform:uppercase;letter-spacing:.3px}
.kpi-sub{font-size:10.5px;color:var(--green);font-weight:700;margin-top:4px}

/* ===== PANELS / CHARTS ===== */
.grid2{display:grid;grid-template-columns:1fr 1fr;gap:18px}
.grid3{display:grid;grid-template-columns:repeat(3,1fr);gap:18px}
.panel{
  background:var(--card);border:2.5px solid #000;border-radius:var(--r);padding:20px;
  box-shadow:var(--shadow);position:relative;
}
.panel-h{display:flex;align-items:center;gap:9px;font-weight:800;font-size:15px;margin-bottom:16px;text-transform:uppercase;font-style:italic;letter-spacing:-.3px}
.panel-h .dot{width:11px;height:11px;border-radius:50%;background:var(--yellow);border:2px solid #000}
.panel-h.g .dot{background:var(--green)}
.chart-wrap{position:relative;height:300px}
.chart-wrap.sm{height:240px}

/* ===== AI BLOCK ===== */
.ai-panel{
  background:linear-gradient(135deg,#16160c 0%,#0d1410 100%);
  border:2.5px solid var(--yellow);border-radius:var(--r);padding:0;box-shadow:var(--shadow);overflow:hidden;
}
.ai-head{display:flex;align-items:center;gap:13px;padding:16px 20px;border-bottom:2px solid #000;background:rgba(0,0,0,.25)}
.ai-orb{width:42px;height:42px;border-radius:12px;background:conic-gradient(from 0deg,var(--yellow),var(--green),var(--yellow));border:2.5px solid #000;display:grid;place-items:center;flex-shrink:0;animation:spin 6s linear infinite}
@keyframes spin{to{transform:rotate(360deg)}}
.ai-orb svg{width:22px;height:22px;animation:spin 6s linear infinite reverse}
.ai-title{font-weight:900;font-style:italic;font-size:17px;text-transform:uppercase;letter-spacing:-.4px}
.ai-title b{color:var(--yellow)}
.ai-chip{font-size:9.5px;font-weight:800;padding:4px 9px;border-radius:20px;border:1.5px solid #000;text-transform:uppercase;letter-spacing:.5px;margin-left:auto;white-space:nowrap}
.ai-chip.live{background:var(--green);color:#000}
.ai-chip.off{background:#3a3a40;color:var(--muted)}
.ai-chip.load{background:var(--yellow);color:#000}
.ai-regen{background:var(--card);border:2px solid #000;border-radius:9px;width:36px;height:36px;display:grid;place-items:center;cursor:pointer;color:var(--white);flex-shrink:0}
.ai-regen:hover{background:var(--yellow);color:#000}
.ai-regen svg{width:18px;height:18px}
.ai-body{padding:20px 22px;font-size:14px;line-height:1.72;color:#E7E7EA}
.ai-body h4{color:var(--yellow);font-size:13px;font-weight:800;text-transform:uppercase;letter-spacing:.4px;margin:16px 0 7px;display:flex;align-items:center;gap:7px}
.ai-body h4:first-child{margin-top:0}
.ai-body h4::before{content:"";width:13px;height:13px;background:var(--green);border:2px solid #000;border-radius:3px;transform:rotate(45deg);flex-shrink:0}
.ai-body p{margin-bottom:10px}
.ai-body ul{margin:6px 0 12px 4px;list-style:none}
.ai-body li{padding-left:22px;position:relative;margin-bottom:6px}
.ai-body li::before{content:"⚡";position:absolute;left:0;color:var(--yellow)}
.ai-body strong{color:var(--white)}
.shimmer-line{height:13px;border-radius:6px;background:linear-gradient(90deg,#1f1f22 25%,#2c2c30 50%,#1f1f22 75%);background-size:200% 100%;animation:shim 1.4s infinite;margin-bottom:11px}
@keyframes shim{to{background-position:-200% 0}}

/* ===== CHIPS / BADGES ===== */
.chip{display:inline-flex;align-items:center;gap:5px;padding:4px 11px;border-radius:20px;font-size:11px;font-weight:800;border:2px solid #000;text-transform:uppercase;letter-spacing:.3px}
.chip.alto{background:var(--green);color:#000}
.chip.medio{background:var(--yellow);color:#000}
.chip.bajo{background:var(--red);color:#fff}
.chip.sin{background:#3a3a40;color:var(--muted)}
.chip.ghost{background:transparent;color:var(--muted);border-color:var(--line)}
.sem{width:14px;height:14px;border-radius:50%;border:2px solid #000;display:inline-block;flex-shrink:0}
.sem.alto{background:var(--green);box-shadow:0 0 10px var(--green)}
.sem.medio{background:var(--yellow);box-shadow:0 0 10px var(--yellow)}
.sem.bajo{background:var(--red);box-shadow:0 0 8px var(--red)}
.sem.sin{background:#444}

/* ===== OBJETIVO / DEP CARDS ===== */
.acc{display:flex;flex-direction:column;gap:14px}
.acc-card{background:var(--card);border:2.5px solid #000;border-radius:var(--r);box-shadow:var(--shadow);overflow:hidden}
.acc-top{display:flex;align-items:center;gap:14px;padding:18px 20px;cursor:pointer;transition:.15s}
.acc-top:hover{background:var(--card2)}
.acc-rank{width:42px;height:42px;flex-shrink:0;border-radius:12px;background:var(--yellow);border:2.5px solid #000;display:grid;place-items:center;font-weight:900;font-size:18px;font-style:italic;color:#000}
.acc-rank.r2{background:var(--green)}.acc-rank.r3{background:var(--white)}
.acc-info{flex:1;min-width:0}
.acc-name{font-weight:800;font-size:15px;line-height:1.3;margin-bottom:6px}
.acc-meta{display:flex;gap:8px;flex-wrap:wrap;align-items:center}
.mini{font-size:11px;color:var(--muted);font-weight:600;display:flex;align-items:center;gap:4px}
.mini b{color:var(--white)}
.acc-prog{width:120px;flex-shrink:0;text-align:right}
.acc-pct{font-size:24px;font-weight:900;font-style:italic;line-height:1}
.acc-bar{height:8px;background:#000;border-radius:6px;overflow:hidden;margin-top:6px;border:1.5px solid #000}
.acc-bar i{display:block;height:100%;border-radius:6px;transition:width .8s ease}
.acc-caret{transition:.2s;color:var(--muted)}
.acc-card.open .acc-caret{transform:rotate(180deg);color:var(--yellow)}
.acc-body{max-height:0;overflow:hidden;transition:max-height .35s ease;border-top:0 solid #000}
.acc-card.open .acc-body{max-height:2600px;border-top:2px solid #000}
.acc-body-in{padding:20px}

table.tbl{width:100%;border-collapse:collapse;font-size:12.5px}
.tbl th{text-align:left;color:var(--green);font-weight:800;font-size:10.5px;text-transform:uppercase;letter-spacing:.4px;padding:8px 10px;border-bottom:2px solid var(--line)}
.tbl td{padding:9px 10px;border-bottom:1px solid var(--line);vertical-align:top;color:#D5D5D9}
.tbl tr:last-child td{border-bottom:none}
.tbl td b{color:var(--white)}

/* ===== INDICATOR CARDS ===== */
.ind-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(340px,1fr));gap:18px}
.ind-card{background:var(--card);border:2.5px solid #000;border-radius:var(--r);box-shadow:var(--shadow);padding:18px;display:flex;flex-direction:column;gap:12px;transition:.2s;position:relative;overflow:hidden}
.ind-card:hover{transform:translateY(-3px);box-shadow:8px 9px 0 #000}
.ind-card::before{content:"";position:absolute;top:0;left:0;width:6px;height:100%;background:var(--ac,var(--yellow))}
.ind-head{display:flex;align-items:flex-start;gap:10px;padding-left:6px}
.ind-name{font-weight:800;font-size:13.5px;line-height:1.32;flex:1}
.ind-obj{font-size:10.5px;color:var(--muted);font-weight:600;margin-top:3px;padding-left:6px;display:flex;align-items:center;gap:5px}
.ind-desc{font-size:12px;color:#C6C6CB;line-height:1.55;background:var(--ink2);border:1.5px solid var(--line);border-radius:10px;padding:11px 13px;max-height:120px;overflow-y:auto}
.ind-desc.empty{color:var(--muted2);font-style:italic}
.ind-ai{font-size:12.3px;line-height:1.62;color:#DCDCE0;border-left:3px solid var(--green);padding:3px 0 3px 12px}
.ind-metrics{display:grid;grid-template-columns:1fr 1fr;gap:9px}
.metric{background:var(--ink2);border:1.5px solid var(--line);border-radius:10px;padding:9px 11px}
.metric .ml{font-size:9px;color:var(--muted);font-weight:700;text-transform:uppercase;letter-spacing:.4px}
.metric .mv{font-size:12.5px;font-weight:800;margin-top:3px;display:flex;align-items:center;gap:6px}
.ind-foot{display:flex;align-items:center;justify-content:space-between;padding-top:4px}
.btn-ai{background:var(--green);color:#000;border:2px solid #000;border-radius:9px;padding:7px 13px;font-weight:800;font-size:11px;cursor:pointer;display:flex;align-items:center;gap:6px;box-shadow:var(--shadow-sm)}
.btn-ai:hover{background:var(--yellow);transform:translate(-1px,-1px)}
.btn-ai:disabled{opacity:.5;cursor:wait}

/* ===== GANTT ===== */
.gantt{background:var(--card);border:2.5px solid #000;border-radius:var(--r);box-shadow:var(--shadow);overflow:hidden}
.gantt-head{display:grid;grid-template-columns:230px 1fr;border-bottom:2px solid #000}
.gantt-head .gh-l{padding:12px 16px;font-size:11px;font-weight:800;color:var(--green);text-transform:uppercase;letter-spacing:.4px}
.gantt-months{display:grid;grid-template-columns:repeat(12,1fr)}
.gm{padding:12px 4px;text-align:center;font-size:10px;font-weight:700;color:var(--muted);border-left:1px solid var(--line)}
.gantt-row{display:grid;grid-template-columns:230px 1fr;border-bottom:1px solid var(--line);transition:.15s}
.gantt-row:hover{background:var(--card2)}
.gr-l{padding:11px 16px;font-size:11.5px;font-weight:600;line-height:1.3;border-right:2px solid #000;display:flex;align-items:center;gap:8px}
.gr-track{position:relative;display:grid;grid-template-columns:repeat(12,1fr);align-items:center;min-height:46px}
.gr-track .gcol{border-left:1px solid var(--line);height:100%}
.gbar{position:absolute;height:22px;border-radius:7px;border:2px solid #000;top:12px;display:flex;align-items:center;padding:0 8px;font-size:10px;font-weight:800;color:#000;white-space:nowrap;overflow:hidden;cursor:default;box-shadow:2px 2px 0 rgba(0,0,0,.5)}
.gbar:hover{filter:brightness(1.08);z-index:5}

/* ===== ADMIN MODAL ===== */
.modal-bg{position:fixed;inset:0;background:rgba(0,0,0,.78);backdrop-filter:blur(4px);z-index:90;display:none;align-items:center;justify-content:center;padding:24px}
.modal-bg.show{display:flex}
.modal{background:var(--ink2);border:3px solid var(--yellow);border-radius:22px;box-shadow:10px 10px 0 #000;max-width:460px;width:100%;padding:26px}
.modal h3{font-weight:900;font-style:italic;font-size:20px;text-transform:uppercase;display:flex;align-items:center;gap:10px;margin-bottom:6px}
.modal h3 .lk{color:var(--green)}
.modal p{color:var(--muted);font-size:12.5px;line-height:1.5;margin-bottom:18px}
.drop{border:2.5px dashed var(--green);border-radius:16px;padding:28px 18px;text-align:center;cursor:pointer;transition:.2s;background:rgba(43,232,107,.04)}
.drop:hover{background:rgba(43,232,107,.1);border-color:var(--yellow)}
.drop svg{width:40px;height:40px;stroke:var(--green);margin-bottom:10px}
.drop b{display:block;font-weight:800;font-size:14px;margin-bottom:4px}
.drop span{font-size:11px;color:var(--muted)}
.modal-actions{display:flex;gap:10px;margin-top:18px}
.ma-btn{flex:1;padding:11px;border-radius:11px;border:2px solid #000;font-weight:800;font-size:12.5px;cursor:pointer;box-shadow:var(--shadow-sm)}
.ma-btn.ghost{background:var(--card);color:var(--white)}
.ma-btn.ghost:hover{background:#26262b}
.ma-btn.danger{background:var(--red);color:#fff}
.ma-close{position:absolute;top:18px;right:20px;cursor:pointer;color:var(--muted);font-size:24px;font-weight:700;line-height:1}
.upload-status{margin-top:14px;font-size:12px;font-weight:700;padding:10px;border-radius:10px;display:none}
.upload-status.ok{display:block;background:rgba(43,232,107,.12);color:var(--green);border:1.5px solid var(--green)}
.upload-status.err{display:block;background:rgba(255,77,94,.12);color:var(--red);border:1.5px solid var(--red)}

.empty-state{text-align:center;padding:60px 20px;color:var(--muted)}
.empty-state svg{width:54px;height:54px;stroke:var(--muted2);margin-bottom:14px}

/* tooltip */
.tt{position:fixed;background:#000;border:2px solid var(--yellow);border-radius:10px;padding:10px 13px;font-size:11.5px;max-width:300px;z-index:100;pointer-events:none;box-shadow:4px 4px 0 rgba(0,0,0,.6);display:none;line-height:1.45}
.tt b{color:var(--yellow)}

/* responsive */
@media(max-width:1080px){.grid2,.grid3{grid-template-columns:1fr}.sidebar{position:fixed;left:0;transform:translateX(0);box-shadow:8px 0 0 rgba(0,0,0,.4)}.sidebar.collapsed{transform:translateX(-100%);width:248px}.gantt-head,.gantt-row{grid-template-columns:150px 1fr}.gr-l{font-size:10px;padding:8px 10px}}
@media(max-width:640px){.content{padding:16px}.topbar{padding:12px 14px}.page-title{font-size:15px;width:100%;order:-1}.kpi-val{font-size:30px}select{max-width:140px}}
.toast{position:fixed;bottom:24px;left:50%;transform:translateX(-50%) translateY(120px);background:var(--green);color:#000;font-weight:800;padding:13px 22px;border-radius:12px;border:2.5px solid #000;box-shadow:var(--shadow);z-index:120;transition:.3s;font-size:13px}
.toast.show{transform:translateX(-50%) translateY(0)}
</style>
</head>
<body>
<div class="app">
  <!-- SIDEBAR -->
