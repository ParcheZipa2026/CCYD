<script>
/* ============================================================
   PARCHE ZIPA · Dashboard CCyD — App Logic
   ============================================================ */
(function(){
'use strict';

/* ---------- STATE ---------- */
let DATA = [];
const filters = { obj:'', dep:'', ind:'' };
let currentPage = 1;
const aiCache = {};            // key -> html
let aiDebounce = null;

/* ---------- KEYWORDS (del brief) ---------- */
const KW = ['socializ','articul','ejecuc','capacit','seguimiento','particip',
            'acompañ','implement','convocat','fortalec','formaci','sensibiliz',
            'estrategia','jornada','taller','campañ','asamblea','sesion','sesión',
            'mesa','informe','atención','atencion','prevención','prevencion'];

/* ---------- NORMALIZE DEPENDENCIAS ---------- */
function canon(frag){
  const t = frag.toLowerCase();
  if(/familia|desarrollo social/.test(t)) return 'Secretaría de Familia';
  if(/salud/.test(t)) return 'Secretaría de Salud';
  if(/segurid/.test(t)) return 'Secretaría de Seguridad';
  if(/desarrollo econ/.test(t)) return 'Sec. Desarrollo Económico';
  if(/rural|ambiente/.test(t)) return 'Sec. Desarrollo Rural y Ambiente';
  if(/educaci/.test(t)) return 'Secretaría de Educación';
  if(/gobierno/.test(t)) return 'Secretaría de Gobierno';
  if(/consejo/.test(t)) return 'Consejo Mpal. de Juventudes';
  if(/plataforma/.test(t)) return 'Plataforma Mpal. de Juventudes';
  if(/casa de la juventud/.test(t)) return 'Casa de la Juventud';
  if(/imcrdz|instituto|cultura/.test(t)) return 'IMCRDZ';
  return frag.trim().replace(/^Sec\.?\s*/i,'Secretaría de ');
}
function splitDeps(s){
  if(!s) return [];
  return s.split(/[–\-—]|,| y (?=Sec|Cons|Plat|Casa|IMC)/i)
          .map(x=>x.trim()).filter(x=>x.length>2)
          .map(canon).filter((v,i,a)=>a.indexOf(v)===i);
}

/* ---------- HEURISTIC ENGINE ---------- */
function analyze(r){
  const desc = (r.descripcion||'').toString().trim();
  const hasDesc = desc.length>0;
  const meta = num(r.metaIndicador), ejec = num(r.ejecucion);
  let ratio = null;
  if(meta!==null && meta>0 && ejec!==null) ratio = ejec/meta;

  // keyword signals
  const low = desc.toLowerCase();
  const kws = KW.filter(k=>low.includes(k));
  const kwSet = new Set();
  kws.forEach(k=>{
    if(/socializ/.test(k))kwSet.add('socialización');
    else if(/articul/.test(k))kwSet.add('articulación');
    else if(/ejecuc/.test(k))kwSet.add('ejecución');
    else if(/capacit|formaci/.test(k))kwSet.add('formación');
    else if(/seguimiento/.test(k))kwSet.add('seguimiento');
    else if(/particip/.test(k))kwSet.add('participación');
    else if(/acompañ/.test(k))kwSet.add('acompañamiento');
    else if(/implement/.test(k))kwSet.add('implementación');
    else if(/convocat|asamblea|sesion|sesión|jornada/.test(k))kwSet.add('convocatoria');
    else if(/fortalec/.test(k))kwSet.add('fortalecimiento');
    else if(/sensibiliz|campañ/.test(k))kwSet.add('sensibilización');
    else if(/taller|estrategia/.test(k))kwSet.add('estrategia');
  });
  const themes = [...kwSet];

  // score
  let s = 0;
  if(ratio!==null){ s += ratio>=0.9?3 : ratio>=0.5?2.2 : ratio>0?1.2 : 0; }
  if(hasDesc){ s += desc.length>450?3 : desc.length>180?2.2 : desc.length>40?1.4 : 0.7; }
  s += Math.min(themes.length,3)*0.7;
  if(/se realiz|se llev|se desarroll|se brinda|se cuenta|se promueve|ofrece/.test(low)) s += 1; // evidencia de hecho
  if(/proyect|programad|dará inicio|a partir de|se encuentra proyectad/.test(low)) s += 0.3; // planeado, no ejecutado

  let avance, color;
  if(!hasDesc && (ratio===null||ratio===0)){ avance='Sin registro'; color='sin'; }
  else if(s>=5.2){ avance='Avance Alto'; color='alto'; }
  else if(s>=2.8){ avance='Avance Medio'; color='medio'; }
  else { avance='Avance Bajo'; color='bajo'; }

  // pct for bars
  let pct;
  if(ratio!==null) pct = Math.min(Math.round(ratio*100),100);
  else pct = color==='alto'?80:color==='medio'?50:color==='bajo'?22:0;

  // riesgo / impacto / recomendacion
  const riesgo = color==='alto'?'Bajo':color==='medio'?'Medio':color==='sin'?'Alto':'Alto';
  const impacto = (themes.includes('articulación')||themes.includes('participación')||themes.includes('fortalecimiento'))&&color==='alto'?'Alto'
                 : color==='alto'?'Medio-Alto' : color==='medio'?'Medio' : 'Por consolidar';

  const cumplimiento = ratio!==null ? Math.round(ratio*100)+'% de la meta' :
                       hasDesc ? 'En desarrollo (cualitativo)' : 'Sin reporte';

  return {avance,color,pct,ratio,meta,ejec,hasDesc,themes,riesgo,impacto,cumplimiento,
          recomendacion:recoText(color,ratio,hasDesc,themes),
          aiText:indicatorNarrative(r,{avance,color,ratio,hasDesc,themes,meta,ejec})};
}

function recoText(color,ratio,hasDesc,themes){
  if(color==='sin') return 'Registrar la descripción de acciones y el dato de ejecución para habilitar la medición.';
  if(color==='bajo') return 'Priorizar la ejecución y documentar evidencia cuantitativa que respalde el avance.';
  if(color==='medio'){
    if(ratio!==null&&ratio<1) return 'Acelerar la ejecución para cerrar la brecha frente a la meta y fortalecer el registro cuantitativo.';
    return 'Consolidar la evidencia y reforzar el seguimiento para asegurar el cumplimiento de la meta.';
  }
  if(themes.includes('articulación')) return 'Mantener la articulación interinstitucional y sistematizar indicadores de impacto.';
  return 'Sostener el ritmo de ejecución y cuantificar el impacto logrado en la población juvenil.';
}

/* indicator-level narrative in the requested institutional style */
function indicatorNarrative(r,a){
  if(a.color==='sin')
    return 'No se registra descripción de acciones realizadas para este indicador. Sin evidencia documental no es posible interpretar el nivel de ejecución; se recomienda registrar el relato de la actividad y el dato cuantitativo de avance.';
  const evid = a.hasDesc ? 'La evidencia registrada' : 'El dato de ejecución reportado';
  let nivel = a.color==='alto'?'una ejecución consistente y sostenida de las actividades previstas'
            : a.color==='medio'?'un desarrollo parcial pero verificable de las actividades previstas'
            : 'un desarrollo inicial de las actividades, aún por consolidar';
  let rel = a.themes.includes('articulación')
        ? 'Las acciones evidencian articulación institucional y guardan relación directa con el indicador'
        : a.themes.length
        ? 'Las acciones desarrolladas guardan relación con el indicador y aportan a su cumplimiento'
        : 'Las acciones reportadas se vinculan al objetivo aunque con evidencia cualitativa limitada';
  let cuant = (a.ratio!==null)
        ? `El reporte cuantitativo (${a.ejec} de ${a.meta}) ${a.ratio>=1?'alcanza o supera':'aún no alcanza'} la meta proyectada`
        : 'Se recomienda fortalecer el registro cuantitativo para facilitar la medición del impacto';
  return `${evid} muestra ${nivel}. ${rel}. ${cuant}.`;
}

/* ---------- HELPERS ---------- */
function num(v){ if(v===null||v===undefined||v==='') return null; const n=Number(v); return isNaN(n)?null:n; }
function esc(s){ return (s==null?'':String(s)).replace(/[&<>"]/g,c=>({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;'}[c])); }
function colorOf(c){ return c==='alto'?'var(--green)':c==='medio'?'var(--yellow)':c==='bajo'?'var(--red)':'#444'; }
function parseDate(s){ if(!s) return null; const m=String(s).match(/(\d{1,2})\/(\d{1,2})\/(\d{4})/); if(!m) return null; return new Date(+m[3],+m[2]-1,+m[1]); }

/* ---------- DERIVED ---------- */
function prep(){
  DATA.forEach((r,i)=>{ r.id=r.id||i+1; r._deps=splitDeps(r.responsable); r._a=analyze(r); });
}
function filtered(){
  return DATA.filter(r=>{
    if(filters.obj && r.objetivo!==filters.obj) return false;
    if(filters.dep && !r._deps.includes(filters.dep)) return false;
    if(filters.ind && r.indicador!==filters.ind) return false;
    return true;
  });
}

/* ============================================================
   NAVIGATION
   ============================================================ */
const PAGES = [
  {n:1,t:'Resumen Ejecutivo',ic:'<path d="M3 13h4v7H3zM10 4h4v16h-4zM17 9h4v11h-4z"/>'},
  {n:2,t:'Por Objetivos',ic:'<circle cx="12" cy="12" r="9"/><circle cx="12" cy="12" r="4"/><circle cx="12" cy="12" r="0.5" fill="currentColor"/>'},
  {n:3,t:'Por Dependencias',ic:'<path d="M3 21h18M5 21V8l7-5 7 5v13M9 21v-6h6v6"/>'},
  {n:4,t:'Indicadores',ic:'<rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/>'},
  {n:5,t:'Cronograma',ic:'<rect x="3" y="4" width="18" height="18" rx="2"/><path d="M3 10h18M8 2v4M16 2v4M7 14h6M7 18h4"/>'},
  {n:6,t:'Narrativa IA',ic:'<path d="M12 2l2 5 5 .5-3.8 3.4L16.5 16 12 13l-4.5 3 1.3-5.1L5 7.5 10 7z"/>'}
];
function buildNav(){
  const nav=document.getElementById('nav');
  nav.innerHTML=PAGES.map(p=>`<div class="nav-item${p.n===currentPage?' active':''}" data-p="${p.n}">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">${p.ic}</svg>
    <span class="nav-label">${p.t}</span><span class="nav-num">0${p.n}</span></div>`).join('');
  nav.querySelectorAll('.nav-item').forEach(el=>el.onclick=()=>goPage(+el.dataset.p));
}
function goPage(n){
  currentPage=n;
  document.querySelectorAll('.nav-item').forEach(e=>e.classList.toggle('active',+e.dataset.p===n));
  const p=PAGES.find(x=>x.n===n);
  document.getElementById('pageTitle').innerHTML=`<b>0${n}</b> ${p.t}`;
  render();
}

/* ============================================================
   FILTERS
   ============================================================ */
function buildFilters(){
  const objs=[...new Set(DATA.map(r=>r.objetivo).filter(Boolean))].sort();
  const deps=[...new Set(DATA.flatMap(r=>r._deps))].sort();
  const inds=[...new Set(DATA.map(r=>r.indicador).filter(Boolean))].sort();
  fill('fObj',objs,'Todos los objetivos');
  fill('fDep',deps,'Todas las dependencias');
  fill('fInd',inds,'Todos los indicadores');
}
function fill(id,arr,all){
  const s=document.getElementById(id);
  s.innerHTML=`<option value="">${all}</option>`+arr.map(v=>`<option value="${esc(v)}">${esc(v.length>46?v.slice(0,44)+'…':v)}</option>`).join('');
}
function bindFilters(){
  ['fObj','fDep','fInd'].forEach((id,i)=>{
    document.getElementById(id).onchange=e=>{
      filters[['obj','dep','ind'][i]]=e.target.value; render();
    };
  });
  document.getElementById('btnClear').onclick=()=>{
    filters.obj=filters.dep=filters.ind='';
    ['fObj','fDep','fInd'].forEach(id=>document.getElementById(id).value='');
    render();
  };
}

/* ============================================================
   RENDER ROUTER
   ============================================================ */
function render(){
  const c=document.getElementById('content');
  const d=filtered();
  if(currentPage===1) renderResumen(c,d);
  else if(currentPage===2) renderObjetivos(c,d);
  else if(currentPage===3) renderDependencias(c,d);
  else if(currentPage===4) renderIndicadores(c,d);
  else if(currentPage===5) renderCronograma(c,d);
  else if(currentPage===6) renderNarrativa(c,d);
  requestAnimationFrame(()=>document.querySelectorAll('.kpi').forEach((k,i)=>setTimeout(()=>k.classList.add('in'),i*70)));
}

/* ---------- PAGE 1: RESUMEN ---------- */
function renderResumen(c,d){
  const acciones=d.length;
  const objetivos=new Set(d.map(r=>r.objetivo).filter(Boolean)).size;
  const deps=new Set(d.flatMap(r=>r._deps)).size;
  const inds=new Set(d.map(r=>r.indicador).filter(Boolean)).size;
  const conDesc=d.filter(r=>r._a.hasDesc).length;
  const lineas=objetivos;
  const dist=countAvance(d);

  c.innerHTML=`
  <div class="tag green">⚡ ¿Cómo va el Plan de Acción?</div>
  <div id="aiSlot"></div>

  <div class="section-gap"></div>
  <div class="kpi-grid">
    ${kpi('Acciones registradas',acciones,'<path d="M9 11l3 3L22 4M21 12v7a2 2 0 01-2 2H5a2 2 0 01-2-2V5a2 2 0 012-2h11"/>','var(--yellow)',conDesc+' con descripción')}
    ${kpi('Objetivos estratégicos',objetivos,'<circle cx="12" cy="12" r="9"/><circle cx="12" cy="12" r="4"/>','var(--green)','del Plan 2026')}
    ${kpi('Dependencias',deps,'<path d="M3 21h18M5 21V8l7-5 7 5v13"/>','var(--white)','participantes')}
    ${kpi('Líneas estratégicas',lineas,'<path d="M4 19h16M4 5v14M8 13l3-3 2 2 5-5"/>','var(--yellow)','en seguimiento')}
    ${kpi('Indicadores',inds,'<rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/>','var(--green)','definidos')}
    ${kpi('Con descripción',conDesc,'<path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><path d="M14 2v6h6M9 13h6M9 17h4"/>','var(--white)',pct(conDesc,acciones)+'% del total')}
  </div>

  <div class="section-gap"></div>
  <div class="panel">
    <div class="panel-h g"><span class="dot"></span>Estado de ejecución del plan</div>
    ${statusBar(dist,d.length)}
  </div>

  <div class="section-gap"></div>
  <div class="grid2">
    <div class="panel"><div class="panel-h"><span class="dot"></span>Acciones por dependencia</div><div class="chart-wrap"><canvas id="chDep"></canvas></div></div>
    <div class="panel"><div class="panel-h g"><span class="dot"></span>Acciones por objetivo</div><div class="chart-wrap"><canvas id="chObj"></canvas></div></div>
  </div>
  <div class="section-gap"></div>
  <div class="panel"><div class="panel-h"><span class="dot"></span>Nivel de avance por objetivo (interpretado)</div><div class="chart-wrap"><canvas id="chAvance"></canvas></div></div>

  <div class="section-gap"></div>
  <div class="panel"><div class="panel-h g"><span class="dot"></span>Cronograma resumido</div>${miniTimeline(d)}</div>
  `;
  renderAISlot('aiSlot','resumen',d);
  drawDepChart(d); drawObjChart(d); drawAvanceChart(d);
}

function kpi(lab,val,ic,col,sub){
  return `<div class="kpi" style="--accent:${col}">
    <div class="kpi-ico" style="--accent:${col}"><svg viewBox="0 0 24 24" fill="none" stroke="#000" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">${ic}</svg></div>
    <div class="kpi-val" data-count="${val}">0</div>
    <div class="kpi-lab">${lab}</div>${sub?`<div class="kpi-sub">${sub}</div>`:''}</div>`;
}
function pct(a,b){ return b?Math.round(a/b*100):0; }

function countAvance(d){
  const o={alto:0,medio:0,bajo:0,sin:0};
  d.forEach(r=>o[r._a.color]++); return o;
