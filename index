/* ============================================================
   UTILS
   ============================================================ */
function groupBy(arr,k){ const o={}; arr.forEach(r=>{const key=r[k]||'(sin asignar)';(o[key]=o[key]||[]).push(r);}); return o; }
function avgPct(arr){ if(!arr.length) return 0; return Math.round(arr.reduce((s,r)=>s+r._a.pct,0)/arr.length); }
function emptyState(t){ return `<div class="empty-state"><svg viewBox="0 0 24 24" fill="none" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="M21 21l-4-4"/></svg><div style="font-weight:700;font-size:15px">${t}</div></div>`; }

function countUp(){
  document.querySelectorAll('[data-count]').forEach(el=>{
    const t=+el.dataset.count; let s=0; const step=Math.max(1,Math.ceil(t/28));
    const iv=setInterval(()=>{ s+=step; if(s>=t){s=t;clearInterval(iv);} el.textContent=s; },24);
  });
}
const _origRender=render;
render=function(){ _origRender(); countUp(); };

function toast(msg){ const t=document.getElementById('toast'); t.textContent=msg; t.classList.add('show'); setTimeout(()=>t.classList.remove('show'),2600); }

function bindTooltips(){
  const tt=document.getElementById('tt');
  document.querySelectorAll('[data-tt]').forEach(el=>{
    el.onmousemove=e=>{ tt.innerHTML=el.dataset.tt; tt.style.display='block';
      let x=e.clientX+14,y=e.clientY+14; if(x+300>innerWidth)x=e.clientX-310; tt.style.left=x+'px'; tt.style.top=y+'px'; };
    el.onmouseleave=()=>tt.style.display='none';
  });
}

/* ============================================================
   ADMIN / UPLOAD (oculto)
   ============================================================ */
function openAdmin(){ document.getElementById('modalBg').classList.add('show'); }
function closeAdmin(){ document.getElementById('modalBg').classList.remove('show'); }
function bindAdmin(){
  document.getElementById('adminDot').onclick=openAdmin;
  document.getElementById('maClose').onclick=closeAdmin;
  document.getElementById('modalBg').onclick=e=>{ if(e.target.id==='modalBg') closeAdmin(); };
  // keyboard shortcut Ctrl+Shift+U
  document.addEventListener('keydown',e=>{ if(e.ctrlKey&&e.shiftKey&&e.key.toLowerCase()==='u'){e.preventDefault();openAdmin();} });
  const drop=document.getElementById('drop'), input=document.getElementById('fileInput');
  drop.onclick=()=>input.click();
  input.onchange=e=>{ if(e.target.files[0]) handleFile(e.target.files[0]); };
  drop.ondragover=e=>{e.preventDefault();drop.style.background='rgba(43,232,107,.14)';};
  drop.ondragleave=()=>drop.style.background='';
  drop.ondrop=e=>{e.preventDefault();drop.style.background='';if(e.dataTransfer.files[0])handleFile(e.dataTransfer.files[0]);};
  document.getElementById('btnRestore').onclick=()=>{
    localStorage.removeItem('parche_data'); DATA=JSON.parse(JSON.stringify(ORIGINAL_DATA));
    prep(); buildFilters(); Object.keys(aiCache).forEach(k=>delete aiCache[k]); render();
    status('ok','Datos originales restaurados ✓'); toast('Datos restaurados'); setTimeout(closeAdmin,900);
  };
}
function status(c,m){ const s=document.getElementById('upStatus'); s.className='upload-status '+c; s.textContent=m; }
function handleFile(file){
  status('ok','Procesando '+file.name+'…');
  const fr=new FileReader();
  fr.onload=ev=>{
    try{
      const wb=XLSX.read(new Uint8Array(ev.target.result),{type:'array'});
      const ws=wb.Sheets[wb.SheetNames.find(n=>/plan/i.test(n))||wb.SheetNames[0]];
      const rows=XLSX.utils.sheet_to_json(ws,{header:1,raw:false,defval:null});
      // find header row containing "Objetivo"
      let hi=rows.findIndex(r=>r&&r.some(c=>String(c||'').trim().toLowerCase()==='objetivo'));
      if(hi<0) hi=2;
      const keys=['objetivo','meta','accion','fechaInicio','fechaFin','indicador','periodicidad','responsable','fuente','metaIndicador','ejecucion','descripcion','entregable','observaciones','periodoReporte'];
      const out=[];
      for(let i=hi+1;i<rows.length;i++){
        const r=rows[i]; if(!r||r.every(c=>c==null||c==='')) continue;
        const rec={id:out.length+1};
        keys.forEach((k,j)=>{ let v=r[j]; if(v!=null&&typeof v!=='number')v=String(v).trim(); rec[k]=(v===''?null:v); });
        // coerce numeric meta/ejec
        rec.metaIndicador=rec.metaIndicador!=null&&!isNaN(+rec.metaIndicador)?+rec.metaIndicador:rec.metaIndicador;
        rec.ejecucion=rec.ejecucion!=null&&!isNaN(+rec.ejecucion)?+rec.ejecucion:rec.ejecucion;
        out.push(rec);
      }
      if(!out.length) throw new Error('No se encontraron filas de datos');
      DATA=out; localStorage.setItem('parche_data',JSON.stringify(out));
      prep(); buildFilters(); filters.obj=filters.dep=filters.ind='';
      ['fObj','fDep','fInd'].forEach(id=>document.getElementById(id).value='');
      Object.keys(aiCache).forEach(k=>delete aiCache[k]); render();
      status('ok',`✓ ${out.length} acciones cargadas correctamente`); toast('Datos actualizados ✓');
      setTimeout(closeAdmin,1100);
    }catch(err){ status('err','✕ Error: '+err.message+'. Verifica el formato del Excel.'); }
  };
  fr.onerror=()=>status('err','✕ No se pudo leer el archivo');
  fr.readAsArrayBuffer(file);
}

/* ============================================================
   INIT
   ============================================================ */
function init(){
  const saved=localStorage.getItem('parche_data');
  DATA = saved?JSON.parse(saved):JSON.parse(JSON.stringify(ORIGINAL_DATA));
  prep(); buildNav(); buildFilters(); bindFilters(); bindAdmin();
  document.getElementById('burger').onclick=()=>document.getElementById('sidebar').classList.toggle('collapsed');
  render();
}
document.addEventListener('DOMContentLoaded',init);
})();

