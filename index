let charts={};
Chart.defaults.color='#8C8C93'; Chart.defaults.font.family='Poppins'; Chart.defaults.font.weight='600';
const PAL=['#F4E500','#2BE86B','#FFFFFF','#F4A300','#9B8CFF','#FF4D5E','#3DD6F4','#FF8AC4','#B6E84C'];
function destroy(id){ if(charts[id]){charts[id].destroy();delete charts[id];} }

function drawDepChart(d){
  const m={}; d.forEach(r=>r._deps.forEach(x=>m[x]=(m[x]||0)+1));
  const e=Object.entries(m).sort((a,b)=>b[1]-a[1]).slice(0,8);
  destroy('chDep');
  charts.chDep=new Chart(document.getElementById('chDep'),{type:'doughnut',
    data:{labels:e.map(x=>x[0]),datasets:[{data:e.map(x=>x[1]),backgroundColor:PAL,borderColor:'#000',borderWidth:2.5,hoverOffset:8}]},
    options:{responsive:true,maintainAspectRatio:false,cutout:'58%',
      plugins:{legend:{position:'right',labels:{boxWidth:12,padding:9,font:{size:10.5}}}}}});
}
function drawObjChart(d){
  const m={}; d.forEach(r=>{if(r.objetivo)m[r.objetivo]=(m[r.objetivo]||0)+1;});
  const e=Object.entries(m).sort((a,b)=>b[1]-a[1]);
  destroy('chObj');
  charts.chObj=new Chart(document.getElementById('chObj'),{type:'bar',
    data:{labels:e.map(x=>x[0].length>28?x[0].slice(0,26)+'…':x[0]),datasets:[{data:e.map(x=>x[1]),backgroundColor:'#2BE86B',borderColor:'#000',borderWidth:2.5,borderRadius:6}]},
    options:{indexAxis:'y',responsive:true,maintainAspectRatio:false,
      plugins:{legend:{display:false}},scales:{x:{grid:{color:'#2A2A2F'},ticks:{precision:0}},y:{grid:{display:false},ticks:{font:{size:10}}}}}});
}
function drawAvanceChart(d){
  const g=groupBy(d,'objetivo'); const ks=Object.keys(g).sort((a,b)=>avgPct(g[b])-avgPct(g[a]));
  destroy('chAvance');
  charts.chAvance=new Chart(document.getElementById('chAvance'),{type:'bar',
    data:{labels:ks.map(k=>k.length>24?k.slice(0,22)+'…':k),datasets:[{label:'% avance',data:ks.map(k=>avgPct(g[k])),
      backgroundColor:ks.map(k=>{const p=avgPct(g[k]);return p>=66?'#2BE86B':p>=35?'#F4E500':'#FF4D5E';}),borderColor:'#000',borderWidth:2.5,borderRadius:6}]},
